# NAS .env — cp .env.example .env 후 값 입력

# Gemini (디디딧 시나리오 머신 공용 키)
GEMINI_API_KEY=

# Google Apps Script 웹 앱 (콘티 시트)
DDDIT_SHEET_API_URL=https://script.google.com/macros/s/...../exec
DDDIT_SHEET_API_TOKEN=

# 팀이 "시트 열기" 할 스프레드시트 URL
DDDIT_SHEET_OPEN_URL=https://docs.google.com/spreadsheets/d/...../edit

# CORS
WORKS_ALLOWED_ORIGINS=https://works.mansejin.com

# NAS 자동 배포 (선택) — api/docs/deploy-nas-auto.md
WORKS_DEPLOY_BRANCH=main
WORKS_DOCKER_SUDO=1

# YouTube (채널 대시보드) — GCP에서 YouTube Data API v3 활성화 후 키 발급
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=DD-DIT
# Analytics OAuth·Ads 동기화에 필요 (채널 ID, UC… 형식)
YOUTUBE_CHANNEL_ID=

# YouTube Analytics API (OAuth2 refresh token — NAS에서 대화형 로그인 없이 사용)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# Google Ads API (YouTube 프로모션 비용·노출 동기화)
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth는 YouTube와 동일 GCP 앱을 쓸 수 있음 (비우면 YOUTUBE_OAUTH_* 사용)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# 고객 ID (하이픈 없이, 예: 1234567890)
GOOGLE_ADS_CUSTOMER_ID=
# MCC(관리 계정) 사용 시 로그인 고객 ID (선택)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

WORKS_PORT=8788
