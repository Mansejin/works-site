# NAS .env — cp .env.example .env 후 값 입력

# Gemini (디디딧 시나리오 머신 공용 키)
GEMINI_API_KEY=

# Google Apps Script 웹 앱 (레거시 — OAuth 방식 권장)
# DDDIT_SHEET_API_URL=https://script.google.com/macros/s/...../exec
# DDDIT_SHEET_API_TOKEN=

# Google Sheets API (권장) — 디디딧 계정 OAuth, Apps Script 웹앱 배포 불필요
# api/scripts/issue-sheets-oauth-token.py 로 1회 발급
# DDDIT_SHEETS_OAUTH_REFRESH_TOKEN=
# DDDIT_SHEETS_DRIVE_FOLDER_ID=

# 팀이 "시트 열기" 할 스프레드시트 URL
DDDIT_SHEET_OPEN_URL=https://docs.google.com/spreadsheets/d/...../edit

# CORS
WORKS_ALLOWED_ORIGINS=https://works.mansejin.com

# 디디딧 워크스페이스 팀 게이트 (내부 페이지 직접 URL 차단)
# 설정 시 /dddit/ · script/ 등은 비밀번호 필요. 브랜드 productlist/plan/conti 는 공개.
DDDIT_TEAM_GATE_PASSCODE=

# NAS 자동 배포 (선택) — api/docs/deploy-nas-auto.md
WORKS_DEPLOY_BRANCH=main
WORKS_DOCKER_SUDO=1

# YouTube (채널 대시보드) — GCP에서 YouTube Data API v3 활성화 후 키 발급
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=DD-DIT
# Analytics OAuth·Ads 동기화에 필요 (채널 ID, UC… 형식)
YOUTUBE_CHANNEL_ID=

# YouTube Analytics API (OAuth2 refresh token — NAS에서 대화형 로그인 없이 사용)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_OAUTH_REFRESH_TOKEN=

# YouTube Reporting API — 썸네일 노출·CTR (동일 OAuth, GCP에서 API 활성화)
# YOUTUBE_REPORTING_JOB_ID=  # 비우면 자동 생성·저장 (data/youtube/reporting-sync.json)
# YOUTUBE_REPORTING_TYPE_ID=channel_reach_basic_a1

# YouTube Studio 프로모션 동기화 (비공식 youtubei — api/docs/studio-promotions-sync.md)
# 캡처(cURL) 저장을 권장. 직접 쿠키를 쓸 때만 아래 설정.
# YOUTUBE_STUDIO_COOKIES=SID=...; HSID=...; SSID=...; APISID=...; SAPISID=...

# Google Ads (YouTube Studio 프로모션은 Ads UI에 안 보이는 경우 많음 — 기본 꺼짐)
# GOOGLE_ADS_SYNC_ENABLED=1
GOOGLE_ADS_DEVELOPER_TOKEN=
# OAuth는 YouTube와 동일 GCP 앱을 쓸 수 있음 (비우면 YOUTUBE_OAUTH_* 사용)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# 고객 ID (하이픈 없이, 예: 1234567890)
GOOGLE_ADS_CUSTOMER_ID=
# MCC로 API 호출 시 필수 (예: 1987587717 — 하이픈 없이)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

WORKS_PORT=8788

# Team gate: set DDDIT_TEAM_GATE_PASSCODE in NAS api/.env then recreate container
